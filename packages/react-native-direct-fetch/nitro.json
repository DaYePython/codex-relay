{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["directfetch"],
  "ios": {
    "iosModuleName": "DirectFetch"
  },
  "android": {
    "androidNamespace": ["directfetch"],
    "androidCxxLibName": "DirectFetch"
  },
  "autolinking": {
    "DirectFetch": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridDirectFetch"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridDirectFetch"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
