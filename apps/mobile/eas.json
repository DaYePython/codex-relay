{
  "cli": {
    "version": ">= 18.8.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "node": "22.22.2",
      "environment": "development",
      "env": {
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
      },
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "node": "22.22.2",
      "environment": "preview",
      "env": {
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
      },
      "distribution": "internal"
    },
    "production": {
      "node": "22.22.2",
      "environment": "production",
      "env": {
        "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
